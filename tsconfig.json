{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "types": ["node"],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "app/api/**/*.ts",
    "app/apply/**/*.tsx",
    "app/company/**/*.tsx",
    "app/dashboard/**/*.tsx",
    "app/jobs/**/*.tsx",
    "app/login/**/*.tsx",
    "app/messages/**/*.tsx",
    "app/notifications/**/*.tsx",
    "app/profile/**/*.tsx",
    "app/signup/**/*.tsx",
    "app/subscription/**/*.tsx",
    "app/layout.tsx",
    "app/page.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "types/**/*.ts",
    "middleware.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src",
    "backend",
    "supabase/functions",
    "app/(auth)/**",
    "app/(dashboard)/**",
    "components/layout/navbar.tsx",
    "lib/api/applications.ts",
    "lib/auth/auth.ts"
  ]
}
